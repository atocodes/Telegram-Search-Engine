# ---- Telegram (MTProto user account) ----
# Get api_id / api_hash from https://my.telegram.org -> API development tools
TG_API_ID=000000
TG_API_HASH=your_api_hash_here
# Phone number of the DEDICATED account (never your personal number)
TG_PHONE=+251900000000
# Session string is generated on first interactive login (see README).
# Storing it lets you swap accounts without re-login.
TG_SESSION_STRING=

# ---- Crawl safety / throttling ----
# Minimum seconds between Telegram API calls (higher = safer).
TG_MIN_DELAY_SECONDS=4
# Extra random jitter added on top of min delay (0..N seconds).
TG_JITTER_SECONDS=3
# Max messages to pull per channel per crawl.
TG_MESSAGES_PER_CHANNEL=40
# Hard cap on channels touched in a single crawl run.
TG_MAX_CHANNELS_PER_RUN=50
# NEVER join channels during discovery (read-only). Keep true.
TG_ALLOW_JOIN=false

# ---- Database (Supabase Postgres) ----
# Use the TRANSACTION POOLER connection (Project Settings > Database > Connect).
#
# IMPORTANT: use the keyword form below, NOT the postgresql:// URI. The Supabase
# pooler truncates the username at the dot when it comes from a URI, so it tries
# to log in as "postgres" instead of "postgres.<project-ref>" and auth fails.
# The keyword form passes the username through intact.
#
# The pooler username is postgres.<project-ref> (note the dot).
# Prepared statements are disabled in code (required for the transaction pooler).
DATABASE_URL=host=aws-1-eu-central-2.pooler.supabase.com port=6543 dbname=postgres user=postgres.your-project-ref password=your-db-password sslmode=require

# ---- Local LLM (Ollama) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---- Meilisearch ----
# If MEILI_URL is blank or the server is unreachable, search transparently
# falls back to Postgres full-text search — nothing breaks.
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=
MEILI_INDEX=channels

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
