# Production env for the self-contained docker-compose stack.
# Copy to .env.prod and fill in. NEVER commit .env.prod.

# Your domain (DNS A record must point at the VPS IP). Caddy gets HTTPS for it.
DOMAIN=tgsearch.example.com

# ---- Database (dockerized Postgres, runs in the stack) ----
# The api builds its DATABASE_URL from these (see docker-compose.yml).
POSTGRES_USER=tgsearch
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=tgsearch

# Meilisearch master key (choose a long random string; used by api + meili).
MEILI_MASTER_KEY=change-me-to-a-long-random-string

# CORS: the public origin of the site. Since the API is internal-only this is
# belt-and-suspenders, but set it to your domain.
CORS_ORIGINS=https://tgsearch.example.com

# Link shown in the demo banner + star button -> your OSS repo.
NEXT_PUBLIC_REPO_URL=https://github.com/youruser/telegram-search-engine
